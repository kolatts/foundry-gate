    <rect x="80" y="458" width="560" height="60" rx="8"
          fill="#0D1520" stroke="#0078D4" stroke-width="1.5" />
    <text x="360" y="482" text-anchor="middle" fill="#E8EEF5" font-size="12" font-weight="600">Azure SQL — FoundryGate Database</text>
    <text x="360" y="502" text-anchor="middle" fill="#A0B0C0" font-size="10">Users · QuotaAllocations · Groups · AuditLog · Keys</text>

    <!-- SQL ↓ API -->
    <line x1="360" y1="518" x2="360" y2="542" stroke="#64748b" stroke-width="1.5" marker-end="url(#arrow)" />
    <text x="366" y="534" fill="#64748b" font-size="10">EF Core</text>

    <!-- ─── FoundryGate.Api (y=544..604) ─── -->
    <rect x="80" y="544" width="560" height="60" rx="8"
          fill="#1a0a2e" stroke="#7C3AED" stroke-width="1.5" />
    <text x="360" y="566" text-anchor="middle" fill="#E8EEF5" font-size="12" font-weight="600">FoundryGate.Api</text>
    <text x="360" y="584" text-anchor="middle" fill="#A0B0C0" font-size="10">ASP.NET Core · Entra auth · Azure Container App</text>
    <text x="360" y="599" text-anchor="middle" fill="#6B7E94" font-size="9">IUserLifecycleService → APIM Mgmt API · IEntraUserSyncService → Microsoft Graph</text>

    <!-- API ↓ Web -->
    <line x1="360" y1="604" x2="360" y2="622" stroke="#64748b" stroke-width="1.5" marker-end="url(#arrow)" />
    <text x="366" y="616" fill="#64748b" font-size="10">REST</text>

    <!-- ─── FoundryGate.Web (y=624..656) ─── -->
    <rect x="80" y="624" width="560" height="32" rx="8"
          fill="#1a0a2e" stroke="#7C3AED" stroke-width="1.5" />
    <text x="360" y="638" text-anchor="middle" fill="#E8EEF5" font-size="12" font-weight="600">FoundryGate.Web</text>
    <text x="360" y="651" text-anchor="middle" fill="#6B7E94" font-size="10">Blazor WASM · Azure Static Web Apps · /me /requests /users /groups /audit</text>
  </svg>
</div>

<style>
  .arch-scroll {
    overflow-x: auto;
  }
</style>
