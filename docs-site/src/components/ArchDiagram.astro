    <!-- ─── FoundryGate.Functions (y=342..412) ─── -->
    <rect x="410" y="342" width="240" height="70" rx="8"
          fill="#1a0a2e" stroke="#7C3AED" stroke-width="1.5" />
    <text x="530" y="366" text-anchor="middle" fill="#E8EEF5" font-size="12" font-weight="600">FoundryGate.Functions</text>
    <text x="530" y="384" text-anchor="middle" fill="#A0B0C0" font-size="10">UsageSyncFunction (15 min)</text>
    <text x="530" y="402" text-anchor="middle" fill="#A0B0C0" font-size="10">MonthlyResetFunction (1st UTC)</text>

    <!-- Functions ↙ SQL (diagonal) -->
