---
// No props — fully hardcoded architecture diagram for FoundryGate
---

<div class="arch-scroll not-content">
  <svg
    viewBox="0 0 720 660"
    xmlns="http://www.w3.org/2000/svg"
    style="width:100%;max-width:720px;height:auto;display:block;margin:1.5rem auto;"
    font-family="system-ui,sans-serif"
  >
    <defs>
      <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="#64748b" />
      </marker>
    </defs>

    <!-- ─── Developer (y=10..82) ─── -->
    <rect x="185" y="10" width="350" height="72" rx="8"
          fill="#111927" stroke="#2D4460" stroke-width="1.5" />
    <text x="360" y="34" text-anchor="middle" fill="#E8EEF5" font-size="13" font-weight="600">Developer (alex@company.com)</text>
    <text x="360" y="52" text-anchor="middle" fill="#A0B0C0" font-size="11">Claude Code · Codex · OpenAI SDK</text>
    <text x="360" y="70" text-anchor="middle" fill="#6B7E94" font-size="10" font-family="ui-monospace,Consolas,monospace">api-key: fg-sub-alex-xxxx</text>

    <!-- Developer → APIM -->
    <line x1="360" y1="82" x2="360" y2="110" stroke="#64748b" stroke-width="1.5" marker-end="url(#arrow)" />
    <text x="366" y="100" fill="#64748b" font-size="10">HTTPS + api-key</text>

    <!-- ─── Azure API Management (y=112..182) ─── -->
    <rect x="80" y="112" width="560" height="70" rx="8"
          fill="#0D1520" stroke="#0078D4" stroke-width="1.5" />
    <text x="360" y="136" text-anchor="middle" fill="#E8EEF5" font-size="13" font-weight="600">Azure API Management</text>
    <text x="360" y="154" text-anchor="middle" fill="#A0B0C0" font-size="11">Product: foundrygate</text>
    <text x="360" y="172" text-anchor="middle" fill="#6B7E94" font-size="10">llm-emit-token-metric → App Insights · Backend: Azure AI Foundry</text>

    <!-- APIM ↙ Foundry -->
    <line x1="210" y1="182" x2="150" y2="240" stroke="#64748b" stroke-width="1.5" marker-end="url(#arrow)" />
    <text x="140" y="220" fill="#64748b" font-size="10">forwards</text>

    <!-- APIM ↘ App Insights -->
    <line x1="510" y1="182" x2="568" y2="240" stroke="#64748b" stroke-width="1.5" marker-end="url(#arrow)" />
    <text x="514" y="220" fill="#64748b" font-size="10">token metrics</text>

    <!-- ─── Azure AI Foundry (y=242..302) ─── -->
    <rect x="50" y="242" width="190" height="60" rx="8"
          fill="#0D1520" stroke="#0078D4" stroke-width="1.5" />
    <text x="145" y="268" text-anchor="middle" fill="#E8EEF5" font-size="12" font-weight="600">Azure AI Foundry</text>
    <text x="145" y="288" text-anchor="middle" fill="#A0B0C0" font-size="10">model deployments</text>

    <!-- ─── Application Insights (y=242..302) ─── -->
    <rect x="468" y="242" width="202" height="60" rx="8"
          fill="#0D1520" stroke="#0078D4" stroke-width="1.5" />
    <text x="569" y="264" text-anchor="middle" fill="#E8EEF5" font-size="12" font-weight="600">Application Insights</text>
    <text x="569" y="282" text-anchor="middle" fill="#A0B0C0" font-size="10">Log Analytics Workspace</text>
    <text x="569" y="297" text-anchor="middle" fill="#6B7E94" font-size="10">token counts / subscription</text>

