---
// Foundry Gate — marketing landing page
// Replaces the Starlight splash; Starlight still handles all /docs/* routes
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Foundry Gate — Token budget management for Azure AI Foundry</title>
  <meta name="description" content="Foundry Gate sits between your teams and Microsoft Foundry — enforcing budgets, surfacing spend, and routing models without changing a line of application code." />
  <meta property="og:title" content="Foundry Gate" />
  <meta property="og:description" content="Token budgets, APIM keys, and quota governance for Azure AI Foundry." />
  <meta property="og:image" content={`${base}og-logo.png`} />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <style>
    /* ── Tokens ─────────────────────────────────────────── */
    :root {
      --fg-bg-base:     #080C12;
      --fg-bg-surface:  #0D1520;
      --fg-bg-raised:   #111927;
      --fg-bg-overlay:  #162032;
      --fg-border-subtle: #1E2D42;
      --fg-border-strong: #2D4460;
      --fg-azure-dim:   #0558A0;
      --fg-azure:       #0078D4;
      --fg-azure-hover: #3BA3E8;
      --fg-azure-neon:  #4DCFFF;
      --fg-ember-soft:  #FFB347;
      --fg-ember:       #F58025;
      --fg-ember-hot:   #FF5400;
      --fg-text-primary:   #E8EEF5;
      --fg-text-secondary: #A0B0C0;
      --fg-text-muted:     #6B7E94;
      --fg-success: #22C55E;
      --fg-info:    #38BDF8;
      --fg-font-ui:   'Inter', system-ui, -apple-system, sans-serif;
      --fg-font-mono: 'Monaspace Argon', 'Fira Code', monospace;
    }

    /* ── Reset ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: var(--fg-bg-base);
      color: var(--fg-text-primary);
      font-family: var(--fg-font-ui);
      -webkit-font-smoothing: antialiased;
    }

    a { text-decoration: none; color: inherit; }

    /* ── Nav ────────────────────────────────────────────── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 68px;
      border-bottom: 1px solid var(--fg-border-subtle);
      position: sticky;
      top: 0;
      background: color-mix(in srgb, var(--fg-bg-base) 82%, transparent);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      z-index: 50;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .nav-logo img {
      height: 48px;
      filter: brightness(1.15) drop-shadow(0 0 6px rgba(77,207,255,0.15));
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .nav-links a {
      padding: 0.4rem 0.75rem;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 500;
      color: var(--fg-text-secondary);
      transition: color 0.18s, background 0.18s;
      position: relative;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: 2px;
      left: 0.75rem;
      right: 0.75rem;
      height: 1px;
      background: var(--fg-azure-neon);
      transform: scaleX(0);
      transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      transform-origin: left;
    }

    .nav-links a:hover {
      color: var(--fg-text-primary);
    }

    .nav-links a:hover::after {
      transform: scaleX(1);
    }

    .nav-signin {
      margin-left: 0.75rem;
      padding: 0.4rem 1.1rem !important;
      background: var(--fg-azure) !important;
      color: #fff !important;
      border-radius: 6px;
      font-weight: 600 !important;
      font-size: 13px;
      transition: background 0.18s, box-shadow 0.22s !important;
    }

    .nav-signin::after { display: none; }

    .nav-signin:hover {
      background: var(--fg-azure-hover) !important;
      box-shadow: 0 0 16px 2px color-mix(in srgb, var(--fg-azure-neon) 30%, transparent) !important;
    }

    /* ── Hero ───────────────────────────────────────────── */
    .hero {
      display: grid;
      grid-template-columns: 1fr 1.15fr;
      gap: 3rem;
      align-items: center;
      min-height: calc(100vh - 68px);
      padding: 3rem 2.5rem 3rem 3.5rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--fg-azure-neon);
      background: color-mix(in srgb, var(--fg-azure) 12%, transparent);
      border: 1px solid color-mix(in srgb, var(--fg-azure) 30%, transparent);
      padding: 0.3rem 0.75rem;
      border-radius: 100px;
      width: fit-content;
    }

    h1 {
      font-size: clamp(2.8rem, 4.5vw, 4.2rem);
      font-weight: 700;
      line-height: 1.08;
      letter-spacing: -0.03em;
      color: var(--fg-text-primary);
    }

    h1 .accent {
      color: var(--fg-azure-neon);
    }

    .hero-sub {
      font-size: 1rem;
      line-height: 1.65;
      color: var(--fg-text-secondary);
      max-width: 38ch;
    }

    .cta-group {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.65rem 1.4rem;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      background: var(--fg-azure);
      color: #fff;
      transition: background 0.2s, box-shadow 0.25s;
    }

    .btn-primary:hover {
      background: var(--fg-azure-hover);
      box-shadow: 0 0 20px 2px color-mix(in srgb, var(--fg-azure-neon) 30%, transparent);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.65rem 1.4rem;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      border: 1px solid var(--fg-border-strong);
      color: var(--fg-text-secondary);
      transition: border-color 0.2s, color 0.2s;
    }

    .btn-secondary:hover {
      border-color: var(--fg-azure);
      color: var(--fg-text-primary);
    }

    /* ── Flow steps ─────────────────────────────────────── */
    .hero-flow {
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      flex-wrap: wrap;
      row-gap: 1rem;
    }

    .flow-step {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      background: var(--fg-bg-surface);
      border: 1px solid var(--fg-border-subtle);
      border-radius: 8px;
      padding: 0.6rem 0.75rem;
      transition: border-color 0.2s;
      flex: 1;
      min-width: 120px;
    }

    .flow-step:hover {
      border-color: var(--fg-border-strong);
    }

    .flow-icon {
      color: var(--fg-azure-neon);
      font-size: 14px;
      line-height: 1.4;
      flex-shrink: 0;
    }

    .flow-label {
      font-size: 11px;
      font-weight: 600;
      color: var(--fg-text-primary);
      margin-bottom: 0.15rem;
    }

    .flow-desc {
      font-size: 10px;
      color: var(--fg-text-muted);
      line-height: 1.4;
    }

    .flow-arrow {
      color: var(--fg-border-strong);
      font-size: 16px;
      padding-top: 0.65rem;
      flex-shrink: 0;
    }

    .hero-icons {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      padding-top: 0.5rem;
    }

    .hero-icons img {
      height: 18px;
      opacity: 0.35;
      filter: invert(1);
    }

    /* ── Dashboard screenshot ───────────────────────────── */
    .dashboard-wrap {
      position: relative;
    }

    .dashboard-wrap::before {
      content: '';
      position: absolute;
      inset: -40px;
      background: radial-gradient(ellipse at 60% 50%,
        color-mix(in srgb, var(--fg-azure) 8%, transparent) 0%,
        transparent 70%);
      pointer-events: none;
    }

    .dashboard-img {
      display: block;
      width: 100%;
      border-radius: 12px;
      border: 1px solid var(--fg-border-subtle);
      box-shadow:
        0 0 0 1px var(--fg-border-subtle),
        0 24px 64px color-mix(in srgb, #000 60%, transparent);
    }

    /* ── Ambient aurora layer ────────────────────────────── */
    .aurora {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 0;
    }

    /* Nebula base — screen blend makes dark areas transparent */
    .aurora-nebula {
      position: absolute;
      inset: 0;
      background: url('/foundry-gate/nebula.png') center / cover no-repeat;
      opacity: 0.28;
      mix-blend-mode: screen;
    }

    .aurora-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(90px);
      will-change: transform;
    }

    .aurora-1 {
      width: 700px; height: 480px;
      background: radial-gradient(ellipse, rgba(0,120,212,0.22) 0%, transparent 70%);
      top: -120px; left: -80px;
      animation: orb1 24s ease-in-out infinite alternate;
    }

    .aurora-2 {
      width: 520px; height: 660px;
      background: radial-gradient(ellipse, rgba(77,207,255,0.11) 0%, transparent 70%);
      top: 8%; right: -130px;
      animation: orb2 30s ease-in-out infinite alternate;
      animation-delay: -14s;
    }

    .aurora-3 {
      width: 820px; height: 380px;
      background: radial-gradient(ellipse, rgba(5,88,160,0.19) 0%, transparent 70%);
      bottom: -60px; left: 18%;
      animation: orb3 20s ease-in-out infinite alternate;
      animation-delay: -7s;
    }

    @keyframes orb1 {
      from { transform: translate(0, 0) scale(1); }
      to   { transform: translate(50px, 35px) scale(1.07); }
    }
    @keyframes orb2 {
      from { transform: translate(0, 0) scale(1); }
      to   { transform: translate(-38px, 30px) scale(0.93); }
    }
    @keyframes orb3 {
      from { transform: translate(0, 0) scale(1); }
      to   { transform: translate(28px, -24px) scale(1.06); }
    }

    /* ── Dot grid (floats above aurora, below content) ── */
    .dot-grid {
      position: fixed;
      inset: 0;
      background-image: radial-gradient(circle, rgba(160,176,192,0.05) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none;
      z-index: 1;
    }

    /* Ensure content layers above ambient */
    main { position: relative; z-index: 2; }

    /* ── Dashboard wrap breathes (opacity-only = no repaint) */
    .dashboard-wrap::before {
      animation: glow-breathe 12s cubic-bezier(0.45, 0, 0.55, 1) infinite alternate;
    }

    @keyframes glow-breathe {
      from { opacity: 0.4; }
      to   { opacity: 1;   }
    }

    /* Neon border ring fades in/out via ::after (opacity only) */
    .dashboard-wrap::after {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: 13px;
      border: 1px solid rgba(77, 207, 255, 0.35);
      pointer-events: none;
      opacity: 0;
      animation: border-breathe 12s cubic-bezier(0.45, 0, 0.55, 1) 1s infinite alternate;
    }

    @keyframes border-breathe {
      from { opacity: 0;    }
      to   { opacity: 1;    }
    }

    /* Remove box-shadow animation — handled by ::after overlay instead */
    @keyframes img-glow { from {} to {} }

    /* ── Animations ─────────────────────────────────────── */
    @keyframes rise {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-eyebrow { animation: rise 0.5s cubic-bezier(0.16,1,0.3,1) 0.05s both; }
    h1            { animation: rise 0.5s cubic-bezier(0.16,1,0.3,1) 0.12s both; }
    .hero-flow    { animation: rise 0.5s cubic-bezier(0.16,1,0.3,1) 0.20s both; }
    .cta-group    { animation: rise 0.5s cubic-bezier(0.16,1,0.3,1) 0.30s both; }
    .hero-icons   { animation: rise 0.5s cubic-bezier(0.16,1,0.3,1) 0.38s both; }
    .dashboard-wrap { animation: rise 0.6s cubic-bezier(0.16,1,0.3,1) 0.18s both; }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; }
    }
  </style>
</head>
<body>

<!-- ─── Ambient background ───────────────────────────────── -->
<div class="aurora" aria-hidden="true">
  <div class="aurora-nebula"></div>
  <div class="aurora-orb aurora-1"></div>
  <div class="aurora-orb aurora-2"></div>
  <div class="aurora-orb aurora-3"></div>
</div>
<div class="dot-grid" aria-hidden="true"></div>

<!-- ─── Nav ─────────────────────────────────────────────── -->
<nav>
  <a href={base} class="nav-logo">
    <img src={`${base}logo-cropped.png`} alt="Foundry Gate" />
  </a>
  <div class="nav-links">
    <a href={`${base}getting-started/why-Foundry Gate/`}>📖 Docs</a>
    <a href={`${base}reference/api/`}>⚡ API</a>
    <a href="https://github.com/kolatts/foundry-gate" target="_blank" rel="noopener">✦ GitHub</a>
    <a href={`${base}getting-started/fork-guide/`} class="nav-signin">Get started →</a>
  </div>
</nav>

<!-- ─── Hero ─────────────────────────────────────────────── -->
<main>
  <section class="hero">

    <!-- Left: copy -->
    <div class="hero-left">
      <span class="hero-eyebrow">⬡ Open source · Azure AI Foundry · .NET 10</span>

      <h1>
        Tokens and budgets,<br />
        <span class="accent">finally</span> in sync.
      </h1>

      <div class="hero-flow">
        <div class="flow-step">
          <span class="flow-icon">⬡</span>
          <div>
            <div class="flow-label">Entra</div>
            <div class="flow-desc">Developers sync automatically from your directory</div>
          </div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step">
          <span class="flow-icon">◈</span>
          <div>
            <div class="flow-label">Budget assigned</div>
            <div class="flow-desc">Monthly token quota, individual APIM key</div>
          </div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step">
          <span class="flow-icon">⬛</span>
          <div>
            <div class="flow-label">APIM enforces</div>
            <div class="flow-desc">Access suspended the moment the cap is hit</div>
          </div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step">
          <span class="flow-icon">↑</span>
          <div>
            <div class="flow-label">Adjust</div>
            <div class="flow-desc">Approve a request or raise the limit in the dashboard</div>
          </div>
        </div>
      </div>

      <div class="cta-group">
        <a href={`${base}getting-started/fork-guide/`} class="btn-primary">
          → Get started
        </a>
        <a href="https://github.com/kolatts/foundry-gate" class="btn-secondary" target="_blank" rel="noopener">
          &lt;/&gt; View on GitHub
        </a>
      </div>

      <div class="hero-icons">
        <img src={`${base}icons.png`} alt="Foundry Gate UI icons" style="height:22px;opacity:0.25;filter:invert(1) brightness(2);" />
      </div>
    </div>

    <!-- Right: dashboard screenshot -->
    <div class="dashboard-wrap">
      <img
        src={`${base}hero-mock.png`}
        alt="Foundry Gate developer quota dashboard"
        class="dashboard-img"
      />
    </div>

  </section>
</main>

</body>
</html>
